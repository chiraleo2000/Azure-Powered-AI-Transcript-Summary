# ==================== TESTING MODE ====================
# Set to False to use real Azure services
LOCAL_TESTING_MODE=False

# ==================== AZURE KEY VAULT ====================
# Key Vault Configuration (Required for production)
AZURE_KEY_VAULT_NAME=ai-summary-keyvault
AZURE_KEY_VAULT_URL=https://ai-summary-keyvault.vault.azure.net/
USE_KEY_VAULT=True

# ==================== AZURE SPEECH SERVICES ====================
# Primary Speech Service (westus)
AZURE_SPEECH_KEY=<managed-by-key-vault>
AZURE_SPEECH_KEY_ENDPOINT=https://westus.api.cognitive.microsoft.com/
AZURE_REGION=westus

# Backup Speech Service (eastus)
AZURE_SPEECH_KEY_BACKUP=<managed-by-key-vault>
AZURE_SPEECH_KEY_ENDPOINT_BACKUP=https://eastus.api.cognitive.microsoft.com/
AZURE_REGION_BACKUP=eastus

# ==================== AZURE OPENAI ====================
AZURE_OPENAI_ENDPOINT=https://ai-summary-internal-openai.cognitiveservices.azure.com/
AZURE_OPENAI_KEY=<managed-by-key-vault>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# ==================== TOKEN CONFIGURATION ====================
# 128k input, 16k output - NO CHUNKING
AZURE_OPENAI_MAX_TOKENS=128000
AZURE_OPENAI_COMPLETION_TOKENS=16000

# Chunking Configuration (DISABLED)
ENABLE_CHUNKING=False
CHUNK_STRATEGY=none
AZURE_OPENAI_CHUNK_SIZE=0
AZURE_OPENAI_OVERLAP_TOKENS=0

# Content Token Budgets (for optimization only)
AI_TOKEN_LIMIT_TRANSCRIPTS=100000
AI_TOKEN_LIMIT_DOCUMENTS=20000
AI_TOKEN_LIMIT_IMAGES=8000

# AI Processing Settings
AI_MAX_PROCESSING_TIME_MINUTES=30
AI_RETRY_ATTEMPTS=3
AI_BATCH_SIZE=5
AI_PROCESSING_TIMEOUT=300

# ==================== AZURE BLOB STORAGE ====================
# Storage connection string (managed by Key Vault in production)
AZURE_BLOB_CONNECTION=<managed-by-key-vault>
AZURE_STORAGE_ACCOUNT_NAME=aisummarymeetingstorage

# SAS Tokens (managed by Key Vault in production)
TRANSCRIPTS_SAS_TOKEN=<managed-by-key-vault>
CHAT_RESPONSES_SAS_TOKEN=<managed-by-key-vault>
USER_PASSWORD_SAS_TOKEN=<managed-by-key-vault>
META_DATA_SAS_TOKEN=<managed-by-key-vault>

# Blob Storage Containers
AZURE_CONTAINER=transcripts
CHAT_RESPONSES_CONTAINER=response-chats
USER_PASSWORD_CONTAINER=user-password
META_DATA_CONTAINER=meta-storage

# ==================== COMPUTER VISION ====================
COMPUTER_VISION_ENDPOINT=https://ai-summary-internal-ocr.cognitiveservices.azure.com/
COMPUTER_VISION_KEY=<managed-by-key-vault>
COMPUTER_VISION_REGION=southeastasia
API_VERSION=v3.2

# ==================== FILE UPLOAD SETTINGS ====================
UPLOAD_MAX_SIZE_MB=500
MAX_FILE_SIZE_BYTES=524288000

# Supported file formats
ALLOWED_LANGS={"en-US": "English (US)", "en-GB": "English (UK)", "es-ES": "Spanish", "fr-FR": "French", "de-DE": "German", "it-IT": "Italian", "pt-BR": "Portuguese (Brazil)", "zh-CN": "Chinese (Simplified)", "ja-JP": "Japanese", "ko-KR": "Korean", "ru-RU": "Russian", "ar-SA": "Arabic", "hi-IN": "Hindi", "th-TH": "Thai", "vi-VN": "Vietnamese"}
AUDIO_FORMATS=wav,mp3,ogg,opus,flac,wma,aac,m4a,amr,webm,speex
VIDEO_FORMATS=mp4,mov,avi,mkv,webm,flv,3gp,wmv
DOCUMENT_FORMATS=pdf,docx,doc,pptx,ppt,xlsx,xls,txt,csv,json
IMAGE_FORMATS=jpg,jpeg,png,bmp,gif,tiff,webp

# ==================== UI CONFIGURATION ====================
LOGO_PATH=static/logo_betime-white.png
APP_TITLE=🎙️🤖 ระบบ AI สำหรับการประชุม
SHOW_TOP_ICONS=False

# ==================== OTHER SETTINGS ====================
DEBUG=False
MAX_CONCURRENT_JOBS=5
DATABASE_PATH=database/ai_conference_service.db

# ==================== SECURITY ====================
# Password salt (managed by Key Vault in production)
PASSWORD_SALT=<managed-by-key-vault>
